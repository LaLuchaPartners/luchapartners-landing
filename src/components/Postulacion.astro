---
import fondoUrl from '../assets/postulacion/fondo.png?url';
---

<div class="postulacion-page" style={`background-image: url('${fondoUrl}')`}>

  <a href="/" class="back-btn" aria-label="Volver">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#331A09" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 18 9 12 15 6"/>
    </svg>
  </a>

  <div class="card">
    <h1 class="card-titulo">Datos Personales</h1>

    <form class="form" enctype="multipart/form-data">
      <div class="field">
        <label for="nombres">Nombres:</label>
        <input type="text" id="nombres" name="nombres" autocomplete="given-name" />
      </div>

      <div class="field">
        <label for="apellidos">Apellidos:</label>
        <input type="text" id="apellidos" name="apellidos" autocomplete="family-name" />
      </div>

      <div class="field">
        <label for="telefono">Teléfono:</label>
        <input type="tel" id="telefono" name="telefono" autocomplete="tel" />
      </div>

      <div class="field">
        <label for="correo">Correo:</label>
        <input type="email" id="correo" name="correo" autocomplete="email" />
      </div>

      <div class="field">
        <label for="distrito">Distrito:</label>
        <input type="text" id="distrito" name="distrito" autocomplete="address-level2" />
      </div>

      <div class="field">
        <label for="puesto">Puesto:</label>
        <input type="text" id="puesto" name="puesto" />
      </div>

      <div class="actions">
        <label class="cv-btn" for="cv-upload" id="cv-label">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#331A09" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66L9.41 17.41a2 2 0 0 1-2.83-2.83l8.49-8.48"/>
          </svg>
          <span id="cv-label-text">Adjuntar CV</span>
          <input type="file" id="cv-upload" name="cv" accept=".pdf,.doc,.docx" style="display:none;" />
        </label>

        <button type="submit" class="send-btn" id="send-btn">Send</button>

        <p id="form-msg" class="form-msg" aria-live="polite"></p>
      </div>
    </form>
  </div>

</div>

<script>
  const form = document.querySelector('.form') as HTMLFormElement;
  const sendBtn = document.getElementById('send-btn') as HTMLButtonElement;
  const cvInput = document.getElementById('cv-upload') as HTMLInputElement;
  const cvLabelText = document.getElementById('cv-label-text') as HTMLSpanElement;
  const msg = document.getElementById('form-msg') as HTMLParagraphElement;

  cvInput.addEventListener('change', () => {
    cvLabelText.textContent = cvInput.files?.[0]?.name ?? 'Adjuntar CV';
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    sendBtn.disabled = true;
    sendBtn.textContent = 'Enviando…';
    msg.textContent = '';
    msg.className = 'form-msg';

    const data = new FormData(form);

    try {
      const res = await fetch('/api/postular', { method: 'POST', body: data });
      const json = await res.json();

      if (json.ok) {
        msg.textContent = '¡Postulación enviada con éxito!';
        msg.classList.add('success');
        form.reset();
        cvLabelText.textContent = 'Adjuntar CV';
      } else {
        msg.textContent = 'Error al enviar. Intenta nuevamente.';
        msg.classList.add('error');
      }
    } catch {
      msg.textContent = 'Error de conexión. Intenta nuevamente.';
      msg.classList.add('error');
    } finally {
      sendBtn.disabled = false;
      sendBtn.textContent = 'Send';
    }
  });
</script>

<style is:global>
  html, body {
    height: 100%;
    overflow: hidden;
  }
</style>

<style>
  @font-face {
    font-family: 'Gilroy-Regular';
    src: url('../assets/open/gilroy-regular.ttf') format('truetype');
    font-weight: 400;
    font-display: swap;
  }

  .postulacion-page {
    width: 100%;
    height: 100dvh;
    overflow: hidden;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: 2rem;
  }

  .back-btn {
    position: absolute;
    top: 2rem;
    left: 2rem;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255,255,255,0.85);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(0,0,0,0.12);
    transition: background 0.2s;
    z-index: 10;
  }

  .back-btn:hover {
    background: #fff;
  }

  .card {
    width: 730px;
    height: 700px;
    background: #fff;
    border-radius: 24px;
    padding: 3rem 3.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.4rem;
    overflow: hidden;
    justify-content: space-between;
  }

  .card-titulo {
    font-family: 'Gilroy-Regular', sans-serif;
    font-size: 1.5rem;
    font-weight: 400;
    color: #331A09;
    text-align: center;
    margin: 0 0 0.5rem;
  }

  .form {
    width: 100%;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    justify-content: space-between;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  label {
    font-family: 'Gilroy-Regular', sans-serif;
    font-size: 0.9rem;
    color: #331A09;
  }

  input[type="text"],
  input[type="tel"],
  input[type="email"] {
    width: 100%;
    height: 38px;
    background: #F2F2F2;
    border: none;
    border-radius: 50px;
    padding: 0 1.25rem;
    font-family: 'Gilroy-Regular', sans-serif;
    font-size: 0.9rem;
    color: #331A09;
    outline: none;
    transition: box-shadow 0.2s;
  }

  input[type="text"]:focus,
  input[type="tel"]:focus,
  input[type="email"]:focus {
    box-shadow: 0 0 0 2px rgba(51, 26, 9, 0.25);
  }

  .actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    margin-top: 0.25rem;
  }

  .cv-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    width: 160px;
    height: 38px;
    border: 1.5px solid #331A09;
    border-radius: 50px;
    color: #331A09;
    font-family: 'Gilroy-Regular', sans-serif;
    font-size: 0.9rem;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    background: transparent;
    padding: 0 0.75rem;
    overflow: hidden;
  }

  #cv-label-text {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }

  .cv-btn:hover {
    background: rgba(51, 26, 9, 0.06);
  }

  .send-btn {
    width: 160px;
    height: 42px;
    background: #E87060;
    border: none;
    border-radius: 50px;
    color: #fff;
    font-family: 'Gilroy-Regular', sans-serif;
    font-size: 1rem;
    cursor: pointer;
    transition: background 0.2s;
  }

  .send-btn:hover {
    background: #d45f4e;
  }

  .send-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .form-msg {
    font-family: 'Gilroy-Regular', sans-serif;
    font-size: 0.85rem;
    min-height: 1.2em;
    text-align: center;
  }

  .form-msg.success { color: #2e7d32; }
  .form-msg.error   { color: #c62828; }

  /* Tablet */
  @media (max-width: 800px) {
    .postulacion-page {
      padding: 2rem 1.5rem;
    }

    .card {
      width: min(730px, 100%);
      height: min(700px, calc(100dvh - 4rem));
      padding: 2rem 2rem;
      gap: 0.9rem;
    }

    .card-titulo {
      font-size: 1.25rem;
    }
  }

  /* Mobile */
  @media (max-width: 480px) {
    .postulacion-page {
      padding: 4rem 1.25rem 1.25rem;
    }

    .back-btn {
      top: 1rem;
      left: 1rem;
    }

    .card {
      width: 100%;
      height: calc(100dvh - 5.25rem);
      padding: 1.5rem 1.25rem;
      gap: 0.6rem;
      border-radius: 41px;
    }

    .card-titulo {
      font-size: 1.1rem;
      margin: 0;
    }

    .field {
      gap: 0.15rem;
    }

    label {
      font-size: 0.78rem;
    }

    input[type="text"],
    input[type="tel"],
    input[type="email"] {
      height: 34px;
      font-size: 0.85rem;
    }

    .cv-btn {
      height: 34px;
      font-size: 0.82rem;
    }

    .send-btn {
      height: 36px;
      font-size: 0.9rem;
    }
  }
</style>
