---
import videoUrl from '../assets/video/planta.mp4?url';
---

<section id="video">
  <div class="video-wrap">
    <video autoplay muted loop playsinline>
      <source src={videoUrl} type="video/mp4" />
    </video>
  </div>
</section>

<style>
  #video {
    width: 100%;
    background: #000;
  }

  .video-wrap {
    width: 100%;
    aspect-ratio: 343 / 156;
    max-height: 785px;
    overflow: hidden;
  }

  .video-wrap video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 480px) {
    .video-wrap {
      aspect-ratio: 4 / 5;
      max-height: none;
    }
  }
</style>
