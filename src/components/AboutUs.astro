---
import lalucha    from '../assets/about-us/lalucha.webp';
import sietesopas from '../assets/about-us/sietesopas.webp';
import pacoyonque from '../assets/about-us/pacoyonque.webp';
---

<section id="about-us">
  <div class="about-grid">

    <div class="about-card" data-index="0">
      <div class="about-card-img">
        <img src={lalucha.src} alt="La Lucha Sanguchería" />
      </div>
      <div class="about-card-body" style="background:#90785F;">
        <h3 class="about-card-title">La Lucha Sanguchería</h3>
        <p class="about-card-desc">
          Buscamos compartir lo mejor de la tradición peruana a través de sánguches
          preparados con ingredientes frescos, recetas caseras y un sabor que hace
          sentir a cada persona como en casa.
        </p>
        <button class="about-card-btn">Ver más</button>
      </div>
    </div>

    <div class="about-card" data-index="1">
      <div class="about-card-img">
        <img src={sietesopas.src} alt="Siete Sopas" />
      </div>
      <div class="about-card-body" style="background:#67794E;">
        <h3 class="about-card-title">Siete Sopas</h3>
        <p class="about-card-desc">
          Creemos en el poder de una buena sopa para reunir, reconfortar y compartir.
          Preparamos cada plato con sabor casero, ingredientes frescos y la calidez
          que nos caracteriza en cada atención.
        </p>
        <button class="about-card-btn">Ver más</button>
      </div>
    </div>

    <div class="about-card" data-index="2">
      <div class="about-card-img">
        <img src={pacoyonque.src} alt="Paco Yonque" />
      </div>
      <div class="about-card-body" style="background:#693D3C;">
        <h3 class="about-card-title">Paco Yonque</h3>
        <p class="about-card-desc">
          Vivimos la pasión por las parrillas, preparando cortes y sabores intensos
          con el toque perfecto de fuego, sazón y buena compañía en cada experiencia.
        </p>
        <button class="about-card-btn">Ver más</button>
      </div>
    </div>

  </div>

  <!-- Controles solo visibles en mobile -->
  <div class="about-slider-controls">
    <button class="about-arrow about-prev" aria-label="Anterior">&#8249;</button>
    <div class="about-dots">
      <span class="about-dot active"></span>
      <span class="about-dot"></span>
      <span class="about-dot"></span>
    </div>
    <button class="about-arrow about-next" aria-label="Siguiente">&#8250;</button>
  </div>
</section>

<style>
  @font-face {
    font-family: 'Fraunces';
    src: url('../assets/about-us/Fraunces-VariableFont_SOFT,WONK,opsz,wght.ttf') format('truetype');
    font-weight: 100 900;
    font-display: swap;
  }

  @font-face {
    font-family: 'Gilroy';
    src: url('../assets/open/gilroy-regular.ttf') format('truetype');
    font-weight: 400;
    font-display: swap;
  }

  #about-us {
    width: 100%;
    background: #fff;
    padding: 4rem 3rem;
    margin-top: 2rem;
  }

  .about-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .about-card {
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 4px 20px rgba(0,0,0,0.10);
  }

  .about-card-img {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    flex-shrink: 0;
  }

  .about-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .about-card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 5.5rem 2.5rem;
    gap: 0.85rem;
  }

  .about-card-title {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 400;
    font-size: clamp(1.3rem, 1.9vw, 2rem);
    color: #ffffff;
    margin: 0;
    line-height: 1.2;
  }

  .about-card-desc {
    font-family: 'Gilroy', sans-serif;
    font-size: clamp(0.88rem, 1.1vw, 1.1rem);
    color: #ffffff;
    line-height: 1.65;
    margin: 0;
  }

  .about-card-btn {
    margin-top: auto;
    padding: 0.4rem 1.4rem;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.75);
    border-radius: 50px;
    color: #ffffff;
    font-family: 'Gilroy', sans-serif;
    font-size: 0.82rem;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .about-card-btn:hover {
    background: rgba(255,255,255,0.15);
    border-color: #ffffff;
  }

  /* Controles ocultos en desktop */
  .about-slider-controls {
    display: none;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    #about-us {
      padding: 0;
      margin-top: 0rem;
      position: relative;
    }

    .about-grid {
      display: block;
      position: relative;
      width: 100%;
      height: 100dvh;
    }

    .about-card {
      position: absolute;
      inset: 0;
      border-radius: 0;
      box-shadow: none;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.5s ease;
    }

    .about-card.active {
      opacity: 1;
      pointer-events: auto;
    }

    .about-card-img {
      aspect-ratio: unset;
      height: 55%;
    }

    .about-card-body {
      flex: 1;
      padding: 2rem 1.75rem 5rem;
      gap: 1rem;
      justify-content: center;
    }

    .about-card-title {
      font-size: 1.5rem;
    }

    .about-card-desc {
      font-size: 0.95rem;
      line-height: 1.6;
    }

    .about-card-btn {
      font-size: 0.85rem;
      padding: 0.5rem 1.8rem;
    }

    /* Controles */
    .about-slider-controls {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1.5rem;
      position: absolute;
      bottom: 1.5rem;
      left: 0;
      right: 0;
      z-index: 10;
    }

    .about-arrow {
      background: transparent;
      border: none;
      color: #ffffff;
      font-size: 2rem;
      line-height: 1;
      cursor: pointer;
      padding: 0.25rem 0.5rem;
      opacity: 0.85;
    }

    .about-dots {
      display: flex;
      gap: 0.5rem;
      align-items: center;
    }

    .about-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(255,255,255,0.45);
      transition: background 0.3s;
    }

    .about-dot.active {
      background: #ffffff;
    }
  }
</style>

<script>
  const isMobile = () => window.innerWidth <= 768;

  if (isMobile()) {
    const cards = Array.from(document.querySelectorAll('#about-us .about-card')) as HTMLElement[];
    const dots  = Array.from(document.querySelectorAll('#about-us .about-dot'))  as HTMLElement[];
    const prev  = document.querySelector('#about-us .about-prev') as HTMLButtonElement;
    const next  = document.querySelector('#about-us .about-next') as HTMLButtonElement;

    let current = 0;

    cards[0].classList.add('active');

    function goTo(index: number) {
      cards[current].classList.remove('active');
      dots[current].classList.remove('active');
      current = (index + cards.length) % cards.length;
      cards[current].classList.add('active');
      dots[current].classList.add('active');
    }

    prev.addEventListener('click', () => goTo(current - 1));
    next.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
  }
</script>
