---
import valorIcon from '../assets/valor/valor.webp';
import manosUrl    from '../assets/valor/manos.mp4?url';
import tiendaUrl   from '../assets/valor/tienda.mp4?url';
import personasUrl from '../assets/valor/personas.mp4?url';
---

<section id="valor">
  <div class="valor-inner">

    <!-- Encabezado -->
    <div class="valor-header">
      <img src={valorIcon.src} alt="Nuestro Crecimiento" class="valor-icon" />
      <div class="valor-header-text">
        <h2 class="valor-title">Nuestro Crecimiento</h2>
        <p class="valor-desc">
          El reflejo del esfuerzo de muchas personas que <strong>creen en lo que hacemos.</strong>
        </p>
      </div>
    </div>

    <!-- Stats -->
    <div class="valor-stats">

      <div class="stat-col stat-manos">
        <div class="stat-video-wrap">
          <video class="stat-video" autoplay muted loop playsinline>
            <source src={manosUrl} type="video/mp4" />
          </video>
        </div>
        <div class="stat-text-wrap">
          <span class="stat-num">+2,000</span>
          <span class="stat-label">Mil colaboradores</span>
        </div>
      </div>

      <div class="valor-divider"></div>

      <div class="stat-col stat-tienda">
        <div class="stat-video-wrap">
          <video class="stat-video" autoplay muted loop playsinline>
            <source src={tiendaUrl} type="video/mp4" />
          </video>
        </div>
        <div class="stat-text-wrap">
          <span class="stat-num">38</span>
          <span class="stat-label">Tiendas en el Perú<br />y en el exterior</span>
        </div>
      </div>

      <div class="valor-divider"></div>

      <div class="stat-col stat-personas">
        <div class="stat-video-wrap">
          <video class="stat-video" autoplay muted loop playsinline>
            <source src={personasUrl} type="video/mp4" />
          </video>
        </div>
        <div class="stat-text-wrap">
          <span class="stat-num">+1,0000</span>
          <span class="stat-label">Millón de clientes al mes</span>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @font-face {
    font-family: 'Fraunces';
    src: url('../assets/about-us/Fraunces-VariableFont_SOFT,WONK,opsz,wght.ttf') format('truetype');
    font-weight: 100 900;
    font-display: swap;
  }

  @font-face {
    font-family: 'Gilroy';
    src: url('../assets/open/gilroy-regular.ttf') format('truetype');
    font-weight: 400;
    font-display: swap;
  }

  /* ════════════════════════════
     DESKTOP
  ════════════════════════════ */
  #valor {
    width: 100%;
    background: #ffffff;
    padding: 5rem 3rem;
    margin-top: 7rem;
  }

  .valor-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .valor-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-left: 3rem;
  }

  .valor-icon {
    width: 70px;
    height: 70px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .valor-header-text {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .valor-title {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 600;
    font-size: clamp(1.6rem, 2vw, 1.75rem);
    color: #1a1a1a;
    margin: 0;
  }

  .valor-desc {
    font-family: 'Gilroy', sans-serif;
    font-size: clamp(0.85rem, 1.1vw, 0.95rem);
    color: #2a2a2a;
    margin: 0;
    line-height: 1.5;
  }

  .valor-desc strong {
    font-family: 'Gilroy', sans-serif;
    font-weight: 700;
  }

  .valor-stats {
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    gap: 0;
  }

  .stat-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.6rem;
    padding: 0 2rem;
  }

  .stat-video-wrap {
    width: 100%;
    height: 128px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .stat-video {
    object-fit: contain;
    display: block;
  }

  .stat-manos    .stat-video { width: 218px; height: 96px;  }
  .stat-tienda   .stat-video { width: 120px; height: 112px; }
  .stat-personas .stat-video { width: 234px; height: 128px; }

  .stat-text-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
  }

  .stat-num {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    font-weight: 400;
    color: #331A09;
    line-height: 1;
  }

  .stat-label {
    font-family: 'Gilroy', sans-serif;
    font-size: clamp(0.75rem, 0.95vw, 0.85rem);
    color: #555555;
    line-height: 1.4;
  }

  .valor-divider {
    width: 2px;
    height: 220px;
    background: #331A0991;
    opacity: 0.57;
    flex-shrink: 0;
  }

  /* ════════════════════════════
     MOBILE
  ════════════════════════════ */
  @media (max-width: 480px) {
    #valor {
      padding: 3rem 1.5rem;
      margin-top: 0;
    }

    .valor-inner {
      gap: 2.5rem;
    }

    /* Header */
    .valor-header {
      padding-left: 0;
      align-items: flex-start;
      gap: 1rem;
    }

    .valor-icon {
      width: 56px;
      height: 56px;
    }

    .valor-title {
      font-size: 1.6rem;
    }

    .valor-desc {
      font-size: 0.95rem;
    }

    /* Stats en columna vertical */
    .valor-stats {
      flex-direction: column;
      gap: 0;
    }

    /* Líneas encima y debajo del bloque */
    .valor-stats::before,
    .valor-stats::after {
      content: '';
      display: block;
      width: 100%;
      height: 1px;
      background: #331A0991;
      opacity: 0.4;
    }

    /* Divisores horizontales entre stats */
    .valor-divider {
      width: 100%;
      height: 1px;
      background: #331A0991;
      opacity: 0.4;
    }

    /* Cada stat: fila con video a la izquierda */
    .stat-col {
      flex: unset;
      width: 100%;
      flex-direction: row;
      align-items: center;
      text-align: left;
      padding: 1.75rem 0;
      gap: 0;
    }

    .stat-video-wrap {
      flex: 0 0 130px;
      width: 130px;
      height: auto;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* Tamaños de video en mobile */
    .stat-manos    .stat-video { width: 90px;  height: auto; }
    .stat-tienda   .stat-video { width: 75px;  height: auto; }
    .stat-personas .stat-video { width: 95px;  height: auto; }

    /* Texto */
    .stat-text-wrap {
      flex: 1;
      align-items: flex-start;
      gap: 0.15rem;
    }

    .stat-num {
      font-size: 2.2rem;
      line-height: 1;
    }

    .stat-label {
      font-size: 0.85rem;
      color: #555555;
      text-align: left;
    }

    /* Ajustes individuales (alineación fina por stat) */
    .stat-manos    .stat-num   { margin-left: 0.5rem; }
    .stat-tienda   .stat-num   { margin-left: 3.3rem; }
    .stat-personas .stat-num   { margin-left: 0; }

    .stat-manos    .stat-label { margin-left: 1rem; }
    .stat-tienda   .stat-label { margin-left: 1rem; }
    .stat-personas .stat-label { margin-left: 0; }
  }
</style>
