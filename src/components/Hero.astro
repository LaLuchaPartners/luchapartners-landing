---
import logos1   from '../assets/hero/logos-1.webp';
import logo2    from '../assets/hero/logo-2.webp';
import videoUrl from '../assets/hero/lp.mp4?url';
---

<section id="hero">

  <div class="hero-video-wrap">
    <video autoplay muted loop playsinline>
      <source src={videoUrl} type="video/mp4" />
    </video>
  </div>

  <div class="hero-footer">
    <div class="hero-footer-inner">
      <p class="hero-text">
        Somos una familia que crea experiencias alrededor de la buena<br />
        comida, estando entre uno de las 5 mejores marcas del rubro.
      </p>
      <div class="hero-logos">
        <img src={logos1.src}  alt="Marcas Lucha Partners" />
        <img src={logo2.src}   alt="Marca" class="logo-sm" />
      </div>
    </div>
  </div>

</section>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@500&display=swap" rel="stylesheet" />

<style>
  #hero {
    width: 100%;
    height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  /* ── Video — ratio nativo 68/35, limitado para no tapar la franja ── */
  .hero-video-wrap {
    width: 100%;
    aspect-ratio: 68 / 35;
    max-height: calc(100dvh - 140px);
    overflow: hidden;
    background: #111;
  }

  .hero-video-wrap video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Franja inferior fija ── */
  .hero-footer {
    flex-shrink: 0;
    width: 100%;
    height: 180px;
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-footer-inner {
    width: 100%;
    max-width: 1100px;
    padding: 0 8rem 0 10rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
  }

  .hero-text {
    font-family: 'Dancing Script', cursive;
    font-size: clamp(1.1rem, 1.6vw, 1.35rem);
    color: #2a2a2a;
    line-height: 1.6;
    margin: 0;
    text-align: left;
  }

  .hero-logos {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-shrink: 0;
  }

  .hero-logos img {
    height: 52px;
    width: auto;
    object-fit: contain;
  }

  .hero-logos img.logo-sm {
    height: 36px;
  }
</style>
