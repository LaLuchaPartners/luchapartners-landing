---
import logos    from '../assets/hero/logos.webp';
import videoUrl from '../assets/hero/lp.mp4?url';
---

<section id="hero">

  <div class="hero-video-wrap">
    <video autoplay muted loop playsinline>
      <source src={videoUrl} type="video/mp4" />
    </video>
  </div>

  <div class="hero-footer">
    <div class="hero-footer-inner">
      <p class="hero-text">
        Somos una familia que crea experiencias alrededor de la buena<br />
        comida, estando entre uno de las 5 mejores marcas del rubro.
      </p>
      <div class="hero-logos">
        <img src={logos.src} alt="Marcas Lucha Partners" />
      </div>
    </div>
  </div>

</section>


<style>
  @font-face {
    font-family: 'UT Sugar Cane';
    src: url('../assets/hero/SUGAR CANE UT REGULAR.TTF') format('truetype');
    font-weight: 400;
    font-display: swap;
  }

  #hero {
    width: 100%;
    height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  /* ── Video ── */
  .hero-video-wrap {
    width: 100%;
    aspect-ratio: 254 / 149;
    max-height: calc(100dvh - 140px);
    overflow: hidden;
    background: #111;
  }

  .hero-video-wrap video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Franja inferior ── */
  .hero-footer {
    flex-shrink: 0;
    width: 100%;
    height: 180px;
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-footer-inner {
    width: 100%;
    max-width: 1100px;
    padding: 0 8rem 0 10rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
  }

  .hero-text {
    font-family: 'UT Sugar Cane', cursive;
    font-size: 30px;
    color: #000;
    line-height: 96%;
    margin: 0;
    text-align: left;
  }

  .hero-logos {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .hero-logos img {
    width: 171.118px;
    height: 42.906px;
    object-fit: contain;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    #hero {
      height: auto;
      min-height: 100dvh;
    }

    .hero-video-wrap {
      width: 100%;
      aspect-ratio: unset;
      height: 65dvh;
      max-height: none;
    }

    .hero-footer {
      height: auto;
      padding: 3.5rem 1.5rem 2rem;
    }

    .hero-footer-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 0;
      gap: 1.5rem;
    }

    .hero-text {
      width: 100%;
      font-size: 1.3rem;
      text-align: center;
    }
  }
</style>
